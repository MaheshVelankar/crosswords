    "clues": {
      "across": [
        {
          "text": "मला साठ म्हणून गोंधळण्याआधी मी हे घालून पदार्थ अतिशय चवदार बनवतो",
          "numeral": 1,
          "references": null
        },
        {
          "text": "राहण्यास हा हवा । आणि वाहती हवा ॥",
          "numeral": 4,
          "references": null
        },
        {
          "text": "बिलात लाव म्हटले की आला राग!",
          "numeral": 5,
          "references": null
        },
        {
          "text": "केर काढून हाक मारल्या मारल्या कवितेतल्यासारखी हासतेस!",
          "numeral": 7,
          "references": null
        },
        {
